# Local Development Environment Variables
# Copy this file to .env and update with your local settings

# Set to 'true' to use local PostgreSQL database
VITE_USE_LOCAL_DB=true

# Local PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
VITE_LOCAL_DB_URL=postgresql://postgres:postgres@localhost:5432/buildings_manager

# API URL (if using backend)
VITE_API_URL=http://localhost:8000

# Supabase settings (kept for fallback or production)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
