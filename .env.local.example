# Local Development Environment Variables
# Copy to .env and set as needed.

# Optional: Postgres URL for backend and seed scripts (backend/.env uses DATABASE_URL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# API base URL. Empty = same origin (all requests go to current host /api/...). Set only if API is on another origin.
# VITE_API_BASE_URL=
VITE_API_BASE_URL=
