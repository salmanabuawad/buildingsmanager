# ---------------------------------------------------------------------------
# Azure PostgreSQL (Israel). Use EITHER DATABASE_URL OR the PG* variables.
# ---------------------------------------------------------------------------
# Option A: single URL (password with special chars should be URL-encoded, e.g. # -> %23)
# DATABASE_URL=postgresql://dbadmin:YOUR_URL_ENCODED_PASSWORD@buildingsmanager-db.postgres.database.azure.com:5432/postgres?sslmode=require

# Option B: separate variables (recommended for local/shell; password can contain # etc.)
# PGHOST=buildingsmanager-db.postgres.database.azure.com
# PGUSER=dbadmin
# PGPORT=5432
# PGDATABASE=postgres
# PGPASSWORD=your-password-here

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
SECRET_KEY=your-secret-key-change-this-in-production

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=assetflow-files
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.azurestaticapps.net
ENVIRONMENT=production
