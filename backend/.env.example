# PostgreSQL Database
DATABASE_URL=postgresql://username:password@your-server:5432/assetflow?sslmode=require

# JWT Secret
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Local filesystem storage base paths
FILES_BASE_PATH=/home/profilegroup/app/uploads
ASSET_FILES_STORAGE_PATH=/home/profilegroup/app/asset_files_storage

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Environment
ENVIRONMENT=production

# Optional: OpenAI / ChatGPT API key (for agent or AI features; do not commit the real key)
# OPENAI_API_KEY=sk-proj-...
