# Azure PostgreSQL Database
DATABASE_URL=postgresql://username:password@your-server.postgres.database.azure.com:5432/assetflow?sslmode=require

# JWT Secret
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=assetflow-files

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-azure-static-web-app.azurestaticapps.net

# Environment
ENVIRONMENT=production
