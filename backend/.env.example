# Database configuration
# Set to 'bolt' to use Bolt's Supabase database, or 'local' to use local PostgreSQL
DB_TYPE=local

# Local PostgreSQL connection (used when DB_TYPE=local)
DATABASE_URL=postgresql://user:password@localhost:5432/buildings_db

# Bolt Supabase connection (used when DB_TYPE=bolt)
# These are automatically set in Bolt environment
SUPABASE_DB_URL=

FRONTEND_URL=http://localhost:5173
