# Azure PostgreSQL Database
DATABASE_URL=postgresql://username:password@your-server.postgres.database.azure.com:5432/assetflow?sslmode=require

# JWT Secret
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File storage (default: local). Path = root dir; main folder = subfolder name.
# Local: STORAGE_PATH=./storage, leave STORAGE_USER/STORAGE_PASSWORD empty.
# Remote: set path to share and STORAGE_USER/STORAGE_PASSWORD if required.
STORAGE_PATH=./storage
STORAGE_MAIN_FOLDER=assetflow-files
STORAGE_USER=
STORAGE_PASSWORD=

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-azure-static-web-app.azurestaticapps.net

# Environment
ENVIRONMENT=production
