# Copy to backend/.env for local development with local Postgres.
# After running scripts/setup_local.ps1 (or setup_local.sh), use the DATABASE_URL it prints.
#
# For deployment: DB credentials can come from a startup script by writing a credentials
# file and setting CREDENTIALS_FILE to its path. See backend/scripts/set-credentials.sh.

# Local Postgres (default from setup_local script)
DATABASE_URL=postgresql://postgres:YOUR_PG_PASSWORD@localhost:5432/buildingsmanager

# JWT (use a long random string in production)
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File storage (default: local). No user/password needed for local.
STORAGE_PATH=./storage
STORAGE_MAIN_FOLDER=assetflow-files
STORAGE_USER=
STORAGE_PASSWORD=

# CORS (Vite dev, Nginx on 80, and common variants)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:80,http://localhost:81,http://127.0.0.1:80,http://127.0.0.1:81,http://localhost,http://127.0.0.1

ENVIRONMENT=development
