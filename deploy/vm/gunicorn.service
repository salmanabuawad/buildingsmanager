[Unit]
Description=AssetFlow Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/assetflow/backend
EnvironmentFile=/var/www/assetflow/.env
ExecStart=/var/www/assetflow/venv/bin/gunicorn --chdir /var/www/assetflow/backend app.main:app \
  --workers 2 \
  --worker-class uvicorn.workers.UvicornWorker \
  --bind 127.0.0.1:8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
