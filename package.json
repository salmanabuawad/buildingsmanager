{
  "name": "assetflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "deploy": "npm run build && netlify deploy --prod",
    "deploy:preview": "npm run build && netlify deploy",
    "deploy:server": "powershell -ExecutionPolicy Bypass -File ./deploy-to-server.ps1",
    "deploy:backend": "powershell -ExecutionPolicy Bypass -File ./deploy-backend-to-server.ps1",
    "deploy:server:all": "powershell -ExecutionPolicy Bypass -File ./deploy-all-to-server.ps1",
    "db:setup": "node -e \"console.log('Run: ./scripts/setup-db.sh (Mac/Linux) or .\\\\scripts\\\\setup-db.bat (Windows)')\"",
    "db:backup": "node -e \"console.log('Run: pg_dump -U postgres buildings_manager > backup.sql')\"",
    "db:restore": "node -e \"console.log('Run: psql -U postgres buildings_manager < backup.sql')\"",
    "db:check": "node supabase/scripts/check-db-state.mjs",
    "db:sync": "node supabase/scripts/sync-with-db.mjs",
    "db:apply": "node supabase/scripts/apply-migration-via-api.mjs",
    "db:push": "node supabase/scripts/push-all-migrations.mjs"
  },
  "dependencies": {
    "ag-grid-community": "^34.3.1",
    "ag-grid-react": "^34.3.1",
    "browser-image-compression": "^2.0.2",
    "docx": "^9.6.1",
    "i18next": "^25.6.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "nodemailer": "^6.9.16",
    "pdfjs-dist": "^5.4.394",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.2.4",
    "react-pdf": "^10.2.0",
    "react-router-dom": "^7.9.6",
    "react-to-print": "^3.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.57.0",
    "@types/jszip": "^3.4.1",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.21"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.54.0"
  }
}
